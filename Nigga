--// Slider
local function makeSlider(y, label, min, max, default, cb)
    local holder = Instance.new("Frame", Main)
    holder.Size = UDim2.new(1, -20, 0, 38)
    holder.Position = UDim2.new(0, 10, 0, y)
    holder.BackgroundTransparency = 1
    holder.BorderSizePixel = 0

    local lbl = Instance.new("TextLabel", holder)
    lbl.Size = UDim2.new(1, 0, 0, 16)
    lbl.Text = label .. ": " .. tostring(default)
    lbl.TextColor3 = ACCENT
    lbl.Font = FONT
    lbl.TextSize = 10
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", holder)
    track.Size = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 1, -8)
    track.BackgroundColor3 = Color3.fromRGB(35, 35, 42)
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), 0, 1, 0)
    fill.BackgroundColor3 = ACCENT
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local dragging = false

    local function update(x)
        local pct = math.clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
        local val = min + (max - min) * pct
        val = max > 10 and math.floor(val + 0.5) or (math.floor(val * 10 + 0.5) / 10)
        fill.Size = UDim2.new(math.clamp((val - min) / (max - min), 0, 1), 0, 1, 0)
        lbl.Text = label .. ": " .. tostring(val)
        cb(val)
        saveConfig()
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(i.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            update(i.Position.X)
        end
    end)
end

