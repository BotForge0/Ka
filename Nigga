--// Safe executor helpers
local function hasExecutorFiles()
    return type(isfile) == "function" 
        and type(readfile) == "function" 
        and type(writefile) == "function"
end

local function saveConfig()
    if not hasExecutorFiles() then return end
    pcall(function()
        local data = {
            Aimbot = Settings.Aimbot,
            ESP = Settings.ESP,
            ShowFOV = Settings.ShowFOV,
            AimPart = Settings.AimPart,
            AimKey = Settings.AimKey,
            MenuKey = Settings.MenuKey.Name,
            Smoothing = Settings.Smoothing,
            FOVRadius = Settings.FOVRadius,
            TeamCheck = Settings.TeamCheck,
            VisibilityCheck = Settings.VisibilityCheck,
        }
        writefile(CONFIG_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadConfig()
    if not hasExecutorFiles() then return end
    if not isfile(CONFIG_FILE) then return end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if not ok or type(decoded) ~= "table" then return end

    if decoded.Aimbot ~= nil then Settings.Aimbot = decoded.Aimbot end
    if decoded.ESP ~= nil then Settings.ESP = decoded.ESP end
    if decoded.ShowFOV ~= nil then Settings.ShowFOV = decoded.ShowFOV end
    if decoded.AimPart ~= nil then Settings.AimPart = decoded.AimPart end
    if decoded.Smoothing ~= nil then Settings.Smoothing = tonumber(decoded.Smoothing) or Settings.Smoothing end
    if decoded.FOVRadius ~= nil then Settings.FOVRadius = tonumber(decoded.FOVRadius) or Settings.FOVRadius end
    if decoded.TeamCheck ~= nil then Settings.TeamCheck = decoded.TeamCheck end
    if decoded.VisibilityCheck ~= nil then Settings.VisibilityCheck = decoded.VisibilityCheck end

    -- AimKey als String speichern (MouseButton1, MouseButton2, oder KeyCode Name)
    if decoded.AimKey ~= nil then
        Settings.AimKey = decoded.AimKey
    end
    if decoded.MenuKey and Enum.KeyCode[decoded.MenuKey] then
        Settings.MenuKey = Enum.KeyCode[decoded.MenuKey]
    end
end

