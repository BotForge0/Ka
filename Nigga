--// AimKey Check (Fixed: korrekte Vergleiche)
local function getAimKeyDown()
    local key = Settings.AimKey
    if key == "MouseButton2" then
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    elseif key == "MouseButton1" then
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    elseif type(key) == "string" and Enum.KeyCode[key] then
        return UserInputService:IsKeyDown(Enum.KeyCode[key])
    end
    return false
end

--// Combat Helpers
local function isAlive(character)
    local hum = character and character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function isVisible(part, character)
    if not Settings.VisibilityCheck then return true end

    local cam    = workspace.CurrentCamera
    local origin = cam.CFrame.Position
    local dir    = part.Position - origin

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {
        LocalPlayer.Character or {}, 
        character
    }

    local result = workspace:Raycast(origin, dir, params)
    return result == nil
end

local function getClosestTarget()
    local cam           = workspace.CurrentCamera
    local mouseLocation = UserInputService:GetMouseLocation()
    local closestPart   = nil
    local closestDist   = Settings.FOVRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            -- Team Check
            if (not Settings.TeamCheck) or (player.Team ~= LocalPlayer.Team) then
                local character = player.Character
                if character and isAlive(character) then
                    local part = character:FindFirstChild(Settings.AimPart)
                        or character:FindFirstChild("Head")
                        or character:FindFirstChild("HumanoidRootPart")

                    if part and isVisible(part, character) then
                        local screenPos, onScreen = cam:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local dist = (
                                Vector2.new(screenPos.X, screenPos.Y) - mouseLocation
                            ).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                closestPart = part
                            end
                        end
                    end
                end
            end
        end
    end

    return closestPart
end

--// Aimbot (Fixed: sicherer CFrame Ansatz)
local function aimAt(part)
    if not part then return end
    local cam    = workspace.CurrentCamera
    local target = CFrame.new(cam.CFrame.Position, part.Position)
    local alpha  = 1 - math.clamp(Settings.Smoothing, 0, 0.99)

    -- Lerp zur Zielrichtung
    local newCFrame = cam.CFrame:Lerp(target, alpha)

    pcall(function()
        cam.CFrame = newCFrame
    end)
end

--// ESP
local ESPObjects = {}

local function removeESP(player)
    local objects = ESPObjects[player]
    if objects then
        for _, obj in pairs(objects) do
            pcall(function() obj:Remove() end)
        end
    end
    ESPObjects[player] = nil
end

local function createESP(player)
    if ESPObjects[player] then return ESPObjects[player] end
    if not hasDrawing then return nil end

    local ok, box  = pcall(function() return Drawing.new("Square") end)
    local ok2, name = pcall(function() return Drawing.new("Text")  end)

    if not ok or not ok2 then return nil end

    box.Thickness    = 1
    box.Color        = ACCENT
    box.Transparency = 0.8
    box.Filled       = false
    box.Visible      = false

    name.Color   = ACCENT
    name.Size    = 13
    name.Center  = true
    name.Outline = true
    name.Text    = player.Name
    name.Visible = false

    ESPObjects[player] = {Box = box, Name = name}
    return ESPObjects[player]
end

local function updateESP()
    local cam = workspace.CurrentCamera
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local objects   = createESP(player)
            local character = player.Character
            local root      = character and character:FindFirstChild("HumanoidRootPart")

            if Settings.ESP and objects and root and isAlive(character) then
                local pos, onScreen = cam:WorldToViewportPoint(root.Position)
                if onScreen then
                    local scale = math.clamp(1000 / math.max(pos.Z, 1), 20, 250)
                    local boxW  = scale
                    local boxH  = scale * 1.5
                    objects.Box.Size     = Vector2.new(boxW, boxH)
                    objects.Box.Position = Vector2.new(pos.X - boxW/2, pos.Y - boxH/2)
                    objects.Box.Visible  = true
                    objects.Name.Position = Vector2.new(pos.X, pos.Y - boxH/2 - 15)
                    objects.Name.Text    = player.Name
                    objects.Name.Visible = true
                else
                    objects.Box.Visible  = false
                    objects.Name.Visible = false
                end
            elseif objects then
                objects.Box.Visible  = false
                objects.Name.Visible = false
            end
        end
    end
end

