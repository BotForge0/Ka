local ESPStorage = {}

local function cleanESP(plr)
    if ESPStorage[plr] then
        for _, obj in pairs(ESPStorage[plr]) do
            pcall(function() obj:Remove() end)
        end
    end
    ESPStorage[plr] = nil
end

local function setupESP(plr)
    if ESPStorage[plr] then return ESPStorage[plr] end
    if not hasDrawing then return nil end

    local objects = {}

    -- Box
    pcall(function()
        local box = Drawing.new("Square")
        box.Visible     = false
        box.Color       = Color3.fromRGB(255, 50, 50)
        box.Thickness   = 1.5
        box.Filled      = false
        objects.Box = box
    end)

    -- Name
    pcall(function()
        local name = Drawing.new("Text")
        name.Visible  = false
        name.Color    = Color3.fromRGB(255, 255, 255)
        name.Size     = 13
        name.Center   = true
        name.Outline  = true
        name.OutlineColor = Color3.fromRGB(0, 0, 0)
        name.Text     = plr.Name
        objects.Name = name
    end)

    -- Healthbar Hintergrund
    pcall(function()
        local bg = Drawing.new("Square")
        bg.Visible   = false
        bg.Color     = Color3.fromRGB(0, 0, 0)
        bg.Thickness = 1
        bg.Filled    = true
        objects.HealthBG = bg
    end)

    -- Healthbar
    pcall(function()
        local hp = Drawing.new("Square")
        hp.Visible   = false
        hp.Color     = Color3.fromRGB(50, 255, 50)
        hp.Thickness = 1
        hp.Filled    = true
        objects.Health = hp
    end)

    ESPStorage[plr] = objects
    return objects
end

local function hideESPObjects(objects)
    if not objects then return end
    pcall(function() if objects.Box      then objects.Box.Visible      = false end end)
    pcall(function() if objects.Name     then objects.Name.Visible     = false end end)
    pcall(function() if objects.HealthBG then objects.HealthBG.Visible = false end end)
    pcall(function() if objects.Health   then objects.Health.Visible   = false end end)
end

local function updateAllESP()
    if not hasDrawing then return end
    local cam = workspace.CurrentCamera
    if not cam then return end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local objects = setupESP(plr)
            if not objects then continue end

            local char  = plr.Character
            local root  = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
            local head  = char and char:FindFirstChild("Head")
            local hum   = char and char:FindFirstChildOfClass("Humanoid")

            if Settings.ESP and char and root and isAlive(char) then
                local ok1, rootScreen, onScreen = pcall(function()
                    return cam:WorldToViewportPoint(root.Position)
                end)
                local ok2, headScreen = pcall(function()
                    if head then
                        return cam:WorldToViewportPoint(head.Position + Vector3.new(0, 0.7, 0))
                    end
                    return cam:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                end)

                if ok1 and onScreen and ok2 then
                    -- Größe berechnen
                    local topY    = headScreen.Y
                    local botY    = rootScreen.Y + (rootScreen.Y - topY) * 0.3
                    local height  = math.max(botY - topY, 10)
                    local width   = height * 0.55
                    local centerX = rootScreen.X

                    -- Box
                    if objects.Box then
                        objects.Box.Size     = Vector2.new(width, height)
                        objects.Box.Position = Vector2.new(centerX - width/2, topY)
                        objects.Box.Visible  = true
                    end

                    -- Name
                    if objects.Name then
                        objects.Name.Position = Vector2.new(centerX, topY - 16)
                        objects.Name.Text     = plr.Name
                        objects.Name.Visible  = true
                    end

                    -- Health Bar
                    if hum and objects.HealthBG and objects.Health then
                        local hpPct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                        local barX  = centerX - width/2 - 6
                        local barH  = height

                        objects.HealthBG.Size     = Vector2.new(4, barH)
                        objects.HealthBG.Position = Vector2.new(barX, topY)
                        objects.HealthBG.Visible  = true

                        objects.Health.Size     = Vector2.new(4, barH * hpPct)
                        objects.Health.Position = Vector2.new(barX, topY + barH * (1 - hpPct))
                        -- Farbe je nach HP
                        objects.Health.Color = Color3.fromRGB(
                            math.floor(255 * (1 - hpPct)),
                            math.floor(255 * hpPct),
                            0
                        )
                        objects.Health.Visible = true
                    end
                else
                    hideESPObjects(objects)
                end
            else
                hideESPObjects(objects)
            end
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(0.1)
        cleanESP(plr)
    end)
end)

Players.PlayerRemoving:Connect(function(plr)
    cleanESP(plr)
end)

--// FPS
local frameCount = 0
local lastTick   = tick()

task.spawn(function()
    while task.wait(1) do
        if not ScreenGui.Parent then break end
        local now = tick()
        local fps = math.floor(frameCount / math.max(now - lastTick, 0.001))
        FPSLabel.Text = "FPS: " .. tostring(fps)
        frameCount = 0
        lastTick   = now
    end
end)

--// Main Loop
RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1

    local mouse = UserInputService:GetMouseLocation()

    -- FOV
    if FOVCircle then
        pcall(function()
            FOVCircle.Position    = mouse
            FOVCircle.Radius      = Settings.FOVRadius
            FOVCircle.Visible     = Settings.ShowFOV
        end)
    end

    -- Aimbot
    if Settings.Aimbot and getAimKeyDown() then
        local target = getTarget()
        if target then
            doAim(target)
        end
    end

    -- ESP
    updateAllESP()
end)

updateUI()
